          "mode": "raw",
          "raw": "{\n  \"name\": \"Paracetamol\",\n  \"dosage\": \"650mg\",\n  \"frequency\": \"daily\",\n  \"timeSlots\": [\"09:00\", \"21:00\"]\n}"
