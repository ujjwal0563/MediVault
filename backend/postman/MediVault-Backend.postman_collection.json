    {
      "name": "16 Upload Report (Cloudinary)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{patientToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "report",
              "type": "file",
              "src": "{{reportFilePath}}"
            },
            {
              "key": "reportType",
              "type": "text",
              "value": "Blood Test"
