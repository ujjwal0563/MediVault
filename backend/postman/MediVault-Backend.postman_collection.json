    {
      "name": "15C Mark Notification Read",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{patientToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/notifications/{{notificationId}}/read",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "notifications",
            "{{notificationId}}",
            "read"
          ]
        }
