    {
      "name": "13 Symptom Check",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{patientToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"symptoms\": \"fever, cough and sore throat since 2 days\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/symptom/check",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "symptom",
            "check"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Symptom check returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Symptom response has expected shape', function () {",
              "  pm.expect(json).to.have.property('result');",
              "  pm.expect(json.result).to.have.property('id');",
              "  pm.expect(json.result).to.have.property('aiConditions');",
              "  pm.expect(Array.isArray(json.result.aiConditions)).to.be.true;",
              "  pm.expect(json.result.aiConditions.length).to.be.greaterThan(0);",
              "  pm.expect(json.result).to.have.property('urgency');",
              "  pm.expect(['low','medium','high']).to.include(json.result.urgency);",
              "});",
              "pm.environment.set('symptomLogId', json.result.id);"
            ]
          }
        }
      ]
