      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const notificationId = pm.environment.get('notificationId');",
              "if (!notificationId) {",
              "  pm.test('Notification ID available for mark read', function () {",
