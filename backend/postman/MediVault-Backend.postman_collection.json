          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Patient dashboard returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Patient dashboard summary shape is valid', function () {",
              "  pm.expect(json).to.have.property('summary');",
              "  pm.expect(json.summary).to.have.property('activeMedicines');",
              "  pm.expect(json.summary).to.have.property('scheduledDosesToday');",
              "  pm.expect(json.summary).to.have.property('unreadNotifications');",
              "  pm.expect(json.summary).to.have.property('recentRecordsCount');",
              "  pm.expect(Array.isArray(json.recentSymptoms)).to.be.true;",
              "  pm.expect(Array.isArray(json.recentReports)).to.be.true;",
              "});"
            ]
          }
        }
      ]
    },
