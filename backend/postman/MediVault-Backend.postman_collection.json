    {
      "name": "05 Patient Dashboard (Patient token)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{patientToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/patient/dashboard",
          "host": [
